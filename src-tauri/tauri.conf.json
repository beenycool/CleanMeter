{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CleanMeter",
  "version": "0.1.0",
  "identifier": "app.cleanmeter.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "CleanMeter",
        "width": 800,
        "height": 100,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/HardwareMonitor"
    ],
    "resources": [
      "../presentmon/presentmon.exe",
      "../presentmon/ignored-processes.txt"
    ]
  }
}
